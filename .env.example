# ── MemeGPT environment variables ────────────────────────────────────────────
# Copy this file to .env and fill in values before running.
# For Docker, most of these are overridden by docker-compose.yml environment blocks.

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama"  — local inference (default, free, needs Ollama running)
# "groq"    — cloud inference (free tier, fast, set GROQ_API_KEY below)
LLM_PROVIDER=ollama

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── Groq (cloud LLM, free tier) ──────────────────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Leave CHROMA_HOST empty → embedded PersistentClient (local dev, no Docker)
# Set CHROMA_HOST=vector-db → HttpClient pointed at the compose service (Docker)
CHROMA_HOST=
CHROMA_PORT=8000

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Set CORS_ALLOW_ALL_ORIGINS=true in production (Render/Railway/Cloud)
# Or list specific origins for production:
CORS_ALLOW_ALL_ORIGINS=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]
