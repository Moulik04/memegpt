# ── MemeGPT environment variables ────────────────────────────────────────────
# Copy this file to .env and fill in values before running.
# For Docker, most of these are overridden by docker-compose.yml environment blocks.

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
# Local dev:  http://localhost:11434
# Docker:     http://ollama:11434  (set automatically by compose)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Leave CHROMA_HOST empty → embedded PersistentClient (local dev, no Docker)
# Set CHROMA_HOST=vector-db → HttpClient pointed at the compose service (Docker)
CHROMA_HOST=
CHROMA_PORT=8000

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Add your frontend origin(s) here
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://127.0.0.1:3000"]
