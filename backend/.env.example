# Copy this file to .env and adjust values if needed.
# .env is git-ignored — never commit this file with real values.

# Ollama — runs locally, completely free, no API key required.
# Install: brew install ollama
# Pull model: ollama pull llama3.1:8b
# Start server: ollama serve
#
# Override these only if you're running Ollama on a different host/port
# or want to use a different model (e.g. mistral:7b, llama3.2:3b).
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Server (defaults shown — only set to override)
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false
# CORS_ORIGINS=["http://localhost:3000"]
